{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tick",
  "version": "0.1.1",
  "identifier": "dev.tadeucci.tick",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tick",
        "width": 340,
        "height": 560,
        "minWidth": 280,
        "minHeight": 300,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
